{
  "name": "band-tools",
  "version": "0.2.0",
  "private": true,
  "description": "Chrome extension for band.us groups.",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "pree2e": "npm run build",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "firefox:run": "web-ext run --source-dir dist/firefox",
    "firefox:lint": "web-ext lint --source-dir dist/firefox",
    "package:chrome": "node scripts/package-chrome.js"
  },
  "dependencies": {
    "bandstand": "^0.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "chrome-webstore-upload-cli": "^4.0.1",
    "esbuild": "^0.24.2",
    "sinon-chrome": "^3.0.1",
    "vitest": "^2.1.8",
    "web-ext": "^10.4.0"
  }
}
